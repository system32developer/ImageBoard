<idea-plugin>
    <id>com.system32dev.ImageBoard</id>

    <name>ImageBoard</name>

    <vendor url="https://github.com/system32developer/">System32_Developer</vendor>

    <description><![CDATA[
Image board for IntelliJ-based IDEs.

Features:
<ul>
<li>Store image references</li>
<li>Quick image preview</li>
<li>Fullscreen image viewer</li>
<li>Persistent image collection</li>
</ul>
]]></description>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyMessageBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                id="Image Board"
                anchor="right"
                factoryClass="com.system32dev.ImageBoardToolWindowFactory"/>
    </extensions>

</idea-plugin>
